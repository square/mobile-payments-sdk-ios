{"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"title":"delayDuration","modules":[{"name":"MobilePaymentsSDKAPI"}],"symbolKind":"property","roleHeading":"Instance Property","role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"delayDuration","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@NSTimeInterval","text":"TimeInterval","kind":"typeIdentifier"}],"externalID":"c:@M@MobilePaymentsSDKAPI@objc(cs)SQMPPaymentParameters(py)delayDuration"},"sections":[],"kind":"symbol","abstract":[{"type":"text","text":"The duration of time after the payment’s creation when Square either cancels or completes the payment. This automatic action applies only to payments that don’t reach a terminal state ("},{"type":"codeVoice","code":"COMPLETED"},{"type":"text","text":", "},{"type":"codeVoice","code":"CANCELED"},{"type":"text","text":", or "},{"type":"codeVoice","code":"FAILED"},{"type":"text","text":") before the "},{"type":"codeVoice","code":"delayDuration"},{"type":"text","text":" time period."},{"type":"text","text":" "},{"type":"text","text":"The type of action (either "},{"type":"codeVoice","code":"cancel"},{"type":"text","text":" or "},{"type":"codeVoice","code":"complete"},{"type":"text","text":") is defined by the "},{"type":"codeVoice","code":"delayAction"},{"type":"text","text":" parameter, and defaults to "},{"type":"codeVoice","code":"cancel"},{"type":"text","text":"."}],"variants":[{"paths":["\/documentation\/mobilepaymentssdkapi\/paymentparameters\/delayduration"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@objc","kind":"attribute"},{"text":" ","kind":"text"},{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"delayDuration","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@NSTimeInterval","text":"TimeInterval","kind":"typeIdentifier"}],"languages":["swift"],"platforms":["iOS"]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This feature is only supported for card payments. This parameter can only be set for a delayed capture payment("},{"type":"codeVoice","code":"autocomplete=false"},{"type":"text","text":"). Payments made with other tender types (e.g. cash) will ignore this parameter."}]}]},{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If a card is dipped or tapped, and "},{"type":"codeVoice","code":"autocomplete=true"},{"type":"text","text":", a default delay duration of 10 minutes will be set."}]}]},{"type":"paragraph","inlineContent":[{"text":"This parameter should be specified as a time duration in seconds, expressed as a ","type":"text"},{"type":"codeVoice","code":"TimeInterval"},{"text":", with a minimum value of 60 seconds. If the duration specified is 0 seconds, the default values listed below will be used.","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Default and maximum values:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"For card present payments, the default and maximum value is 36 hours, or 129,600 seconds.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"For card not present payments (such as manual card entry), the default and maximum value is 7 days, or 604,800 seconds.","type":"text"}],"type":"paragraph"}]}]}]}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/mobilepaymentssdkapi-docs.MobilePaymentsSDKAPI\/documentation\/MobilePaymentsSDKAPI","doc:\/\/mobilepaymentssdkapi-docs.MobilePaymentsSDKAPI\/documentation\/MobilePaymentsSDKAPI\/PaymentParameters"]]},"identifier":{"url":"doc:\/\/mobilepaymentssdkapi-docs.MobilePaymentsSDKAPI\/documentation\/